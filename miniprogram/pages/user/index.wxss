.user-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 48rpx;
}

.login-card,
.feature-card,
.metric-card,
.recommend-card,
.admin-card,
.dev-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
}

.login-top {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.avatar-picker {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #fff7ea;
}

.login-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.login-main {
  flex: 1;
}

.login-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
}

.login-subtitle,
.feature-tip,
.recommend-note,
.env-text {
  display: block;
  margin-top: 10rpx;
  color: var(--color-subtext);
  font-size: 24rpx;
  line-height: 1.6;
}

.login-input {
  height: 76rpx;
  margin-top: 18rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  background: #fff8ef;
  font-size: 24rpx;
}

.role-chip {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #fff6e7;
  color: #ff8c00;
  font-size: 22rpx;
  font-weight: 600;
}

.login-actions,
.dev-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.primary-button,
.light-button {
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.primary-button {
  background: linear-gradient(135deg, #ffa500, #ff8c00);
  color: #fff;
}

.light-button {
  background: #fff6e7;
  color: #ff8c00;
}

.feature-grid,
.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.feature-title,
.metric-value,
.recommend-name {
  font-size: 30rpx;
  font-weight: 700;
}

.metric-label,
.section-subtitle {
  display: block;
  color: var(--color-subtext);
  font-size: 22rpx;
}

.metric-value {
  display: block;
  margin-top: 14rpx;
}

.recommend-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
}
