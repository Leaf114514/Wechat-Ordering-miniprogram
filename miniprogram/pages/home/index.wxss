.home-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
}

.hero,
.section,
.action-banner {
  margin-bottom: 24rpx;
  padding: 30rpx;
}

.hero {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  background:
    linear-gradient(135deg, rgba(255, 165, 0, 0.16), rgba(255, 255, 255, 0.94));
}

.hero-main {
  flex: 1;
}

.hero-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
}

.hero-subtitle,
.hero-address {
  display: block;
  margin-top: 12rpx;
  color: var(--color-subtext);
  font-size: 24rpx;
}

.hero-actions {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.ghost-button,
.manage-button,
.hero-card-button,
.primary-button {
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.ghost-button,
.manage-button.light {
  background: #fff7ea;
  color: #ff8c00;
}

.manage-button,
.hero-card-button,
.primary-button {
  background: linear-gradient(135deg, #ffa500, #ff8c00);
  color: #fff;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.hero-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.hero-card {
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #fff9f2;
}

.hero-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 20rpx;
}

.hero-card-main {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.hero-card-title {
  font-size: 30rpx;
  font-weight: 700;
}

.hero-card-desc {
  margin-top: 12rpx;
  color: var(--color-subtext);
  font-size: 22rpx;
  line-height: 1.6;
}

.hero-card-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: auto;
}

.hero-card-price,
.sales-price {
  color: #ff4d4f;
  font-size: 28rpx;
  font-weight: 700;
}

.empty-card {
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 24rpx;
  background: #fff9f2;
}

.empty-title,
.action-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-subtitle,
.action-subtitle {
  display: block;
  margin-top: 12rpx;
  color: var(--color-subtext);
  font-size: 24rpx;
  line-height: 1.6;
}

.sales-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.sales-card {
  position: relative;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #fff9f2;
}

.sales-image {
  width: 100%;
  height: 220rpx;
  border-radius: 18rpx;
}

.sales-rank {
  position: absolute;
  left: 30rpx;
  top: 30rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 140, 0, 0.9);
  color: #fff;
  font-size: 20rpx;
}

.sales-name {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.4;
}

.sales-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 12rpx;
}

.sales-count {
  color: var(--color-subtext);
  font-size: 22rpx;
}

.action-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 0;
}
