.home-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
}

.hero,
.section,
.welcome-card,
.state-card {
  margin-bottom: 24rpx;
  padding: 30rpx;
}

.hero {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  background:
    radial-gradient(circle at top left, rgba(255, 181, 74, 0.22), transparent 36%),
    linear-gradient(135deg, rgba(255, 165, 0, 0.18), rgba(255, 255, 255, 0.96));
}

.hero-main {
  flex: 1;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
}

.hero-subtitle,
.hero-address {
  display: block;
  margin-top: 12rpx;
  color: var(--color-subtext);
  font-size: 24rpx;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.hero-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #d9720c;
  font-size: 20rpx;
}

.hero-metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.metric-pill {
  min-width: 180rpx;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.72);
}

.metric-label {
  display: block;
  color: var(--color-subtext);
  font-size: 20rpx;
}

.metric-value {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.hero-actions {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.ghost-button,
.manage-button,
.hero-card-button,
.primary-button {
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.ghost-button,
.manage-button.light {
  background: #fff7ea;
  color: #ff8c00;
}

.manage-button,
.hero-card-button,
.primary-button {
  background: linear-gradient(135deg, #ffa500, #ff8c00);
  color: #fff;
}

.welcome-card,
.state-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.state-title,
.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
}

.state-subtitle,
.empty-subtitle {
  display: block;
  margin-top: 12rpx;
  color: var(--color-subtext);
  font-size: 24rpx;
  line-height: 1.6;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.hero-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.hero-card {
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #fff9f2;
}

.hero-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 20rpx;
}

.hero-card-main {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.hero-card-title {
  font-size: 30rpx;
  font-weight: 700;
}

.hero-card-desc {
  margin-top: 12rpx;
  color: var(--color-subtext);
  font-size: 22rpx;
  line-height: 1.6;
}

.hero-card-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: auto;
}

.hero-card-price,
.sales-price,
.guess-price {
  color: #ff4d4f;
  font-size: 28rpx;
  font-weight: 700;
}

.hero-card-meta {
  display: block;
  margin-top: 8rpx;
  color: var(--color-subtext);
  font-size: 20rpx;
}

.empty-card {
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 24rpx;
  background: #fff9f2;
}

.guess-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.guess-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: #fff9f2;
}

.guess-main {
  flex: 1;
}

.guess-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
}

.guess-reason {
  display: block;
  margin-top: 10rpx;
  color: var(--color-subtext);
  font-size: 22rpx;
  line-height: 1.5;
}

.sales-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.sales-card {
  position: relative;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #fff9f2;
}

.sales-image {
  width: 100%;
  height: 220rpx;
  border-radius: 18rpx;
}

.sales-rank {
  position: absolute;
  left: 30rpx;
  top: 30rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 140, 0, 0.9);
  color: #fff;
  font-size: 20rpx;
}

.sales-name {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.4;
}

.sales-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 12rpx;
}

.sales-count {
  color: var(--color-subtext);
  font-size: 22rpx;
}
