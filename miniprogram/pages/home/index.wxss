.home-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 240rpx;
}

.hero {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 32rpx;
  background:
    linear-gradient(135deg, rgba(255, 165, 0, 0.18), rgba(255, 255, 255, 0.96));
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
}

.hero-subtitle,
.hero-address {
  display: block;
  margin-top: 12rpx;
  color: var(--color-subtext);
  font-size: 24rpx;
}

.hero-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ghost-button,
.ghost-link {
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  color: #ff8c00;
  font-size: 24rpx;
  font-weight: 600;
}

.recommend,
.remark-box {
  margin-top: 24rpx;
  padding: 28rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.recommend-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: #fff9f2;
}

.recommend-image {
  width: 96rpx;
  height: 96rpx;
  border-radius: 18rpx;
}

.recommend-main {
  flex: 1;
}

.recommend-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
}

.recommend-reason {
  display: block;
  margin-top: 8rpx;
  color: var(--color-subtext);
  font-size: 22rpx;
}

.category-scroll {
  margin-top: 24rpx;
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
}

.category-chip {
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.8);
  color: #666;
  font-size: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.category-chip.is-active {
  background: linear-gradient(135deg, #ffa500, #ff8c00);
  color: #fff;
}

.remark-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
}

.remark-input {
  height: 84rpx;
  margin-top: 18rpx;
  padding: 0 22rpx;
  border-radius: 22rpx;
  background: #fff8ef;
  font-size: 24rpx;
}

.waterfall {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.waterfall-column {
  flex: 1;
}

.load-tip {
  padding: 16rpx 0 32rpx;
  color: var(--color-subtext);
  text-align: center;
  font-size: 22rpx;
}
