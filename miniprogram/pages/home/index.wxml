<view class="home-page fade-enter">
  <view class="hero card-surface">
    <view>
      <text class="hero-title">{{restaurantProfile.name}}</text>
      <text class="hero-subtitle">{{restaurantProfile.slogan}}</text>
      <text class="hero-address">{{restaurantProfile.address}}</text>
    </view>
    <view class="hero-actions">
      <button class="ghost-button" bindtap="handleNavigate"
        data-url="/pages/orders/index">
        我的订单
      </button>
      <button class="ghost-button" bindtap="handleNavigate"
        data-url="/pages/profile/index">
        个人中心
      </button>
    </view>
  </view>

  <view class="recommend card-surface">
    <view class="section-head">
      <view>
        <text class="section-title">智能推荐</text>
        <text class="section-subtitle">
          基于历史订单协同过滤，为你推荐更对味的组合
        </text>
      </view>
      <button class="ghost-link" bindtap="handleNavigate"
        data-url="/pages/admin/index">
        管理后台
      </button>
    </view>
    <view class="recommend-list">
      <view wx:for="{{recommendList}}" wx:key="_id" class="recommend-item">
        <image class="recommend-image" src="{{item.image}}" mode="aspectFill" />
        <view class="recommend-main">
          <text class="recommend-name">{{item.name}}</text>
          <text class="recommend-reason">{{item.reason}}</text>
        </view>
      </view>
    </view>
  </view>

  <scroll-view scroll-x class="category-scroll" show-scrollbar="false">
    <view class="category-list">
      <view
        wx:for="{{categories}}"
        wx:key="*this"
        class="category-chip {{activeCategory === item ? 'is-active' : ''}}"
        bindtap="handleCategoryTap"
        data-category="{{item}}"
      >
        {{item}}
      </view>
    </view>
  </scroll-view>

  <view class="remark-box card-surface">
    <text class="remark-label">订单备注</text>
    <input
      class="remark-input"
      placeholder="如：少冰、不要香菜、打包"
      value="{{remark}}"
      bindinput="handleRemarkInput"
    />
  </view>

  <view class="waterfall">
    <view class="waterfall-column">
      <dish-card
        wx:for="{{leftColumn}}"
        wx:key="_id"
        dish="{{item}}"
        bind:select="handleDishSelect"
        bind:add="handleAddDish"
      />
    </view>
    <view class="waterfall-column">
      <dish-card
        wx:for="{{rightColumn}}"
        wx:key="_id"
        dish="{{item}}"
        bind:select="handleDishSelect"
        bind:add="handleAddDish"
      />
    </view>
  </view>

  <view wx:if="{{!hasMore}}" class="load-tip">已经到底啦，换个分类试试</view>

  <cart-panel
    items="{{cartItems}}"
    summary="{{cartSummary}}"
    bind:change="handleCartChange"
    bind:checkout="handleCheckout"
  />
  <spec-popup
    visible="{{specPopupVisible}}"
    dish="{{activeDish}}"
    bind:close="handleSpecClose"
    bind:confirm="handleSpecConfirm"
  />
</view>
