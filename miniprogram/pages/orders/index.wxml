<view class="orders-page fade-enter">
  <view class="orders-head card-surface">
    <view>
      <text class="section-title">{{isAdminView ? '订单处理台' : '我的订单'}}</text>
      <text class="section-subtitle">{{isAdminView ? '在这里统一处理待支付、制作中与已完成订单。' : '查看待支付、制作中、已完成与已取消的订单状态。'}}</text>
    </view>
    <button class="ghost-button" bindtap="goOrderTab">返回点餐</button>
  </view>

  <view wx:if="{{!hasLogin}}" class="empty card-surface">
    <text class="empty-title">你还没有登录</text>
    <text class="empty-subtitle">登录后即可查看自己的订单记录与状态变化。</text>
    <button class="ghost-button" bindtap="goUserTab">去登录</button>
  </view>

  <block wx:if="{{hasLogin}}">
    <scroll-view scroll-x class="filter-scroll" show-scrollbar="false">
      <view class="filter-list">
        <view
          wx:for="{{filterList}}"
          wx:key="key"
          class="filter-chip {{activeStatus === item.key ? 'is-active' : ''}}"
          bindtap="handleFilterTap"
          data-status="{{item.key}}"
        >
          {{item.text}}
        </view>
      </view>
    </scroll-view>

    <view wx:if="{{loading && !orderList.length}}" class="empty card-surface">
      <text class="empty-title">订单加载中</text>
      <text class="empty-subtitle">正在同步最新订单状态，请稍候。</text>
    </view>

    <view wx:if="{{errorMessage && !orderList.length}}" class="empty card-surface">
      <text class="empty-title">订单加载失败</text>
      <text class="empty-subtitle">{{errorMessage}}</text>
      <button class="ghost-button" bindtap="loadOrders">重新加载</button>
    </view>

    <view wx:if="{{!loading && !errorMessage && !orderList.length}}" class="empty card-surface">
      <text class="empty-title">当前筛选下暂无订单</text>
      <text class="empty-subtitle">去点餐页挑选一份喜欢的餐食吧。</text>
    </view>

    <view
      wx:for="{{orderList}}"
      wx:key="_id"
      wx:for-item="order"
      wx:for-index="orderIndex"
      class="order-card card-surface"
    >
      <view class="order-head">
        <view>
          <text class="order-id">订单号 {{order._id}}</text>
          <text class="order-time">{{order.createdAtText}}</text>
        </view>
        <status-chip status="{{order.status}}" />
      </view>

      <text class="order-remark">备注：{{order.remarkText}}</text>

      <view
        wx:for="{{order.items}}"
        wx:key="itemKey"
        wx:for-item="dish"
        class="order-item"
      >
        <image class="order-image" src="{{dish.image}}" mode="aspectFill" />
        <view class="order-main">
          <text class="order-name">{{dish.name}}</text>
          <text class="order-spec">{{dish.selectionText}}</text>
        </view>
        <view class="order-side">
          <text class="order-item-price">¥{{dish.priceText}}</text>
          <text class="order-meta">x{{dish.quantity}}</text>
        </view>
      </view>

      <view class="order-foot">
        <view>
          <text class="order-total">合计 ¥{{order.totalPriceText}}</text>
          <text class="order-count">共 {{order.itemCount}} 件</text>
        </view>
        <view class="order-actions">
          <button
            wx:for="{{order.actions}}"
            wx:key="key"
            wx:for-item="action"
            wx:for-index="actionIndex"
            class="order-action {{action.danger ? 'is-danger' : ''}}"
            bindtap="handleOrderAction"
            data-index="{{orderIndex}}"
            data-action="{{action.key}}"
          >
            {{action.text}}
          </button>
        </view>
      </view>
    </view>
  </block>
</view>
