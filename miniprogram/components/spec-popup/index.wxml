<view wx:if="{{visible}}" class="popup-mask" catchtap="close">
  <view class="popup-panel" catchtap="noop">
    <view class="popup-head">
      <image class="popup-image" src="{{dish.image}}" mode="aspectFill" />
      <view class="popup-info">
        <text class="popup-title">{{dish.name}}</text>
        <text class="popup-desc">{{dish.description}}</text>
        <text class="popup-stock">当前库存 {{dish.stock}}</text>
      </view>
      <button class="popup-close" bindtap="close">×</button>
    </view>

    <view wx:for="{{dish.specs}}" wx:key="name" wx:for-item="group" class="spec-group">
      <text class="spec-title">{{group.name}}</text>
      <view class="spec-options">
        <view
          wx:for="{{group.options}}"
          wx:key="label"
          wx:for-item="option"
          class="spec-option {{selectedMap[group.name] === option.label ? 'is-active' : ''}}"
          bindtap="handleOptionTap"
          data-group="{{group.name}}"
          data-option="{{option.label}}"
        >
          <text>{{option.label}}</text>
          <text wx:if="{{option.delta}}">+¥{{option.delta}}</text>
        </view>
      </view>
    </view>

    <view class="popup-footer">
      <view class="quantity-box">
        <button class="qty-button" bindtap="decrease">-</button>
        <text class="qty-value">{{quantity}}</text>
        <button class="qty-button" bindtap="increase">+</button>
      </view>
      <button
        class="confirm-button ripple {{!dish.stock ? 'is-disabled' : ''}}"
        bindtap="confirm"
        disabled="{{!dish.stock}}"
      >
        {{dish.stock ? '加入购物车 ¥' + finalPriceText : '当前已售罄'}}
      </button>
    </view>
  </view>
</view>
