.dish-card {
  overflow: hidden;
  margin-bottom: 24rpx;
}

.dish-image {
  width: 100%;
  height: 252rpx;
  border-radius: 8px;
  display: block;
}

.dish-content {
  position: relative;
  padding: 24rpx;
}

.dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.dish-tag {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 165, 0, 0.12);
  color: #ff8c00;
  font-size: 20rpx;
}

.dish-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
}

.dish-desc {
  display: block;
  min-height: 72rpx;
  margin-top: 12rpx;
  color: var(--color-subtext);
  font-size: 24rpx;
  line-height: 1.5;
}

.dish-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 22rpx;
}

.dish-price {
  color: #ff4d4f;
  font-size: 28rpx;
  font-weight: 700;
}

.dish-origin {
  margin-left: 12rpx;
  color: #bfbfbf;
  font-size: 22rpx;
  text-decoration: line-through;
}

.add-button {
  min-width: 164rpx;
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ffa500, #ff8c00);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 14rpx 28rpx rgba(255, 140, 0, 0.18);
}
