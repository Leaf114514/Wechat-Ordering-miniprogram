.dish-card {
  display: flex;
  align-items: stretch;
  gap: 18rpx;
  margin-bottom: 18rpx;
  padding: 18rpx;
  overflow: hidden;
}

.dish-image {
  flex-shrink: 0;
  width: 176rpx;
  height: 176rpx;
  border-radius: 24rpx;
  background: #fff3df;
}

.dish-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 14rpx;
}

.dish-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.dish-head {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.dish-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.dish-name {
  flex: 1;
  overflow: hidden;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-rating {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #fff6e7;
  color: #ff8c00;
  font-size: 20rpx;
}

.dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.dish-tag {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 165, 0, 0.12);
  color: #ff8c00;
  font-size: 18rpx;
  line-height: 1.2;
}

.dish-desc {
  overflow: hidden;
  display: -webkit-box;
  color: var(--color-subtext);
  font-size: 22rpx;
  line-height: 1.55;
  word-break: break-all;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.dish-meta {
  display: flex;
  gap: 18rpx;
  color: var(--color-subtext);
  font-size: 20rpx;
}

.dish-footer {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 12rpx;
}

.dish-price-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
}

.dish-price-group {
  display: flex;
  align-items: flex-end;
  flex-wrap: wrap;
  min-width: 0;
}

.dish-price {
  color: #ff4d4f;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
}

.dish-origin {
  margin-left: 10rpx;
  color: #bfbfbf;
  font-size: 20rpx;
  line-height: 1;
  text-decoration: line-through;
}

.dish-actions {
  display: flex;
  justify-content: flex-end;
  width: 100%;
}

.add-button {
  width: 144rpx;
  max-width: 100%;
  min-width: 0;
  height: 48rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 600;
  white-space: nowrap;
  background: linear-gradient(135deg, #ffa500, #ff8c00);
  color: #fff;
  box-shadow: 0 8rpx 18rpx rgba(255, 140, 0, 0.14);
}

.add-button.is-disabled {
  background: #d7d7d7;
  color: #f8f8f8;
  box-shadow: none;
}
