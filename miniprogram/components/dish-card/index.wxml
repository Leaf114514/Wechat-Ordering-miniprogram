<view class="dish-card card-surface ripple" bindtap="handleTap">
  <image
    class="dish-image"
    src="{{dish.image}}"
    mode="aspectFill"
    lazy-load
  />
  <view class="dish-content">
    <view class="dish-tags">
      <text wx:for="{{dish.tags}}" wx:key="*this" class="dish-tag">
        {{item}}
      </text>
    </view>
    <text class="dish-name">{{dish.name}}</text>
    <text class="dish-desc">{{dish.description}}</text>
    <view class="dish-bottom">
      <view>
        <text class="dish-price">¥{{dish.priceText}}</text>
        <text wx:if="{{dish.originPriceText}}" class="dish-origin">
          ¥{{dish.originPriceText}}
        </text>
      </view>
      <button class="add-button" catchtap="handleAdd">加入购物车</button>
    </view>
  </view>
</view>
