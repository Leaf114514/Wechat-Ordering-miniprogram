page {
  --color-primary: #ffa500;
  --color-primary-dark: #ff8c00;
  --color-accent: #ff5c3c;
  --color-text: #2f2f2f;
  --color-subtext: #8a8a8a;
  --color-surface: #ffffff;
  --color-page: #f5f5f5;
  --color-line: #ececec;
  --shadow-card: 0 16rpx 48rpx rgba(255, 165, 0, 0.12);
  background: linear-gradient(180deg, #fff8ef 0%, #f5f5f5 28%);
  color: var(--color-text);
  font-family: 'Source Han Sans SC', 'PingFang SC', sans-serif;
}

view,
text,
button,
input,
textarea,
scroll-view,
image {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: none;
  background: transparent;
  line-height: 1;
}

button::after {
  border: none;
}

.ripple {
  overflow: hidden;
  position: relative;
}

.ripple:active {
  transform: scale(0.98);
}

.fade-enter {
  animation: fadeEnter 360ms ease;
}

.scale-pop {
  animation: scalePop 220ms ease;
}

.card-surface {
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 28rpx;
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.35;
}

.section-subtitle {
  margin-top: 8rpx;
  color: var(--color-subtext);
  font-size: 24rpx;
}

@keyframes fadeEnter {
  from {
    opacity: 0;
    transform: translate3d(0, 20rpx, 0);
  }

  to {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
}

@keyframes scalePop {
  0% {
    transform: scale(0.92);
  }

  100% {
    transform: scale(1);
  }
}
